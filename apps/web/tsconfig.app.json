{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@relay-api/ui": ["../../packages/ui/src"],
      "@relay-api/ui/*": ["../../packages/ui/src/*"],
      "@relay-api/lib": ["../../packages/lib/src"],
      "@relay-api/lib/*": ["../../packages/lib/src/*"]
    }
  },
  "include": ["src", "../../packages/ui/src", "../../packages/lib/src"]
}
